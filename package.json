{
  "name": "@ominity/next",
  "version": "1.1.0",
  "description": "Next.js App Router integration layer for Ominity CMS.",
  "homepage": "https://github.com/ominity/next#readme",
  "bugs": {
    "url": "https://github.com/ominity/next/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ominity/next.git"
  },
  "license": "BSD-2-Clause",
  "author": "Ominity",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cms": {
      "types": "./dist/cms/index.d.ts",
      "default": "./dist/cms/index.js"
    },
    "./rendering": {
      "types": "./dist/rendering/index.d.ts",
      "default": "./dist/rendering/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "default": "./dist/forms/index.js"
    },
    "./commerce": {
      "types": "./dist/commerce/index.d.ts",
      "default": "./dist/commerce/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./debug": {
      "types": "./dist/debug/index.d.ts",
      "default": "./dist/debug/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "pnpm build && node --test tests/**/*.test.mjs",
    "prepublishOnly": "pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@ominity/api-typescript": "^1.1.1",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.56.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependencies": {
    "@ominity/api-typescript": "^1.1.1",
    "next": "^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    }
  }
}
